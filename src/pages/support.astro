---
import LegalPageLayout from "../layouts/LegalPageLayout.astro";
---

<LegalPageLayout
	title="Support — Simbi: Bedtime Stories"
	heading="Need Help with Simbi?"
	subtitle="We're here to help. If you have a question or issue, reach out and we'll do our best to get it sorted."
	description="Get support for Simbi: Bedtime Stories. Contact us about accounts, subscriptions, stories, bugs, or privacy."
>

<div class="contact-highlight">
	<p>Email us at <a href="mailto:support@getsimbi.com">support@getsimbi.com</a></p>
</div>

<h2>We can help with</h2>
<div class="support-cards">
	<div class="support-card">
		<span class="card-label">Accounts</span>
		<span class="card-value">Account setup, login issues, and profile management</span>
	</div>
	<div class="support-card">
		<span class="card-label">Subscriptions</span>
		<span class="card-value">Billing, plan changes, trials, and cancellations</span>
	</div>
	<div class="support-card">
		<span class="card-label">Stories</span>
		<span class="card-value">Story generation, personalisation, and content questions</span>
	</div>
	<div class="support-card">
		<span class="card-label">Audio</span>
		<span class="card-value">Playback issues, narration, and sound settings</span>
	</div>
	<div class="support-card">
		<span class="card-label">Bug Reports</span>
		<span class="card-value">Something not working? Let us know</span>
	</div>
	<div class="support-card">
		<span class="card-label">Privacy &amp; Data</span>
		<span class="card-value">Data requests, account deletion, and privacy questions</span>
	</div>
</div>

<h2>App details</h2>
<div class="support-cards">
	<div class="support-card">
		<span class="card-label">App Name</span>
		<span class="card-value">Simbi: Bedtime Stories</span>
	</div>
	<div class="support-card">
		<span class="card-label">Developer</span>
		<span class="card-value">Matthew Smart</span>
	</div>
	<div class="support-card">
		<span class="card-label">Website</span>
		<span class="card-value"><a href="https://getsimbi.com">getsimbi.com</a></span>
	</div>
	<div class="support-card">
		<span class="card-label">Platform</span>
		<span class="card-value">iPhone &amp; iPad</span>
	</div>
</div>

<h2>Related pages</h2>
<ul>
	<li><a href="/privacy">Privacy Policy</a></li>
	<li><a href="/privacy-choices">Privacy Choices</a></li>
	<li><a href="/terms">Terms of Service</a></li>
</ul>

<h2>Response time</h2>
<p>We aim to respond within 24–72 hours.</p>

</LegalPageLayout>
